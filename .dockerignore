# =============================================================================
# Docker Ignore File
# =============================================================================
# Prevents unnecessary files from being included in Docker build context
# =============================================================================

# Dependencies
node_modules/
.pnpm-store/
.yarn/

# Build output
dist/
build/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local
.dev.vars
.env.docker.local

# Database files (if any local SQLite files)
*.db
*.db-shm
*.db-wal

# Docker files (don't need to copy these)
docker-compose*.yml
.dockerignore
Dockerfile*

# Docker volumes
docker/postgres/data/
docker/pgadmin/data/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.github/

# Documentation (not needed in containers)
*.md
plans/
docs/

# Temporary files
tmp/
temp/
*.tmp

# Drizzle migrations (generated, not source)
drizzle/migrations/*.sql

# Husky
.husky/_/

# Wrangler
.wrangler/
wrangler.toml

# Misc
*.pid
*.seed
*.pid.lock
