{
  "name": "artha-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "push": "drizzle-kit push",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "db:m": "drizzle-kit generate && drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "fl": "oxlint && oxfmt --write .",
    "format": "oxfmt --write",
    "lint": "oxlint",
    "check": "tsgo --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@hono/zod-validator": "^0.4.3",
    "@upstash/redis": "^1.36.2",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@typescript/native-preview": "^7.0.0-dev.20260314.1",
    "bun-types": "^1.3.8",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.73.0"
  }
}