{
  "name": "artha-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "format": "oxfmt . -w",
    "format:check": "oxfmt . --check",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "check:ci": "bun run typecheck:tsc && bun run lint && bun run format:check",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "diagnose": "bun run scripts/diagnose-types.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "docker:psql": "docker-compose exec postgres psql -U artha -d artha",
    "docker:wait": "bash scripts/wait-for-db.sh",
    "docker:migrate": "bash scripts/wait-for-db.sh && bun run db:migrate",
    "docker:seed": "bash scripts/wait-for-db.sh && bun run db:seed",
    "prepare": "husky"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@hono/zod-validator": "^0.4.3",
    "@upstash/redis": "^1.36.2",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@typescript/native-preview": "^7.0.0-dev.20260314.1",
    "bun-types": "^1.3.8",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.73.0"
  }
}
